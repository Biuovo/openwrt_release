#!/bin/sh

THERMAL_PATH="/sys/class/thermal"
CPU_PATH="/sys/devices/system/cpu"

fmt_temp() {
	awk 'BEGIN{v=ARGV[1]+0; if (v > 1000) v=v/1000; printf("%.1f°C", v)}' "$1"
}

fmt_freq() {
	awk 'BEGIN{v=ARGV[1]+0; if (v >= 1000000) printf("%.2fGHz", v/1000000); else printf("%dMHz", v/1000)}' "$1"
}

read_freq() {
	local cpu="$1"
	local f=""
	[ -r "$CPU_PATH/cpu${cpu}/cpufreq/scaling_cur_freq" ] && f=$(cat "$CPU_PATH/cpu${cpu}/cpufreq/scaling_cur_freq" 2>/dev/null)
	[ -n "$f" ] || [ ! -r "$CPU_PATH/cpu${cpu}/cpufreq/cpuinfo_cur_freq" ] || f=$(cat "$CPU_PATH/cpu${cpu}/cpufreq/cpuinfo_cur_freq" 2>/dev/null)
	[ -n "$f" ] && fmt_freq "$f"
}

cpu_count() {
	ls -d "$CPU_PATH"/cpu[0-9]* 2>/dev/null | sed 's#.*/cpu##' | grep -E '^[0-9]+$' | sort -n | tail -n 1 | awk '{print $1 + 1}'
}

read_cpu_freq_info() {
	local model n little big avg sum cnt v cpu
	model=$(tr '\0' ' ' </proc/device-tree/model 2>/dev/null)
	n=$(cpu_count)

	# NanoPi R76S / RK3588S: cpu0-3 are LITTLE cores, cpu4-7 are big cores.
	if echo "$model $(cat /proc/cpuinfo 2>/dev/null)" | grep -Eiq 'R76S|RK3588|rk3588|NanoPi R6S|NanoPi-R6S'; then
		little=$(read_freq 0)
		big=$(read_freq 4)
		[ -n "$little$big" ] && echo -n "Freq: Little(0-3): ${little:-N/A}, Big(4-7): ${big:-N/A}" && return
	fi

	if [ -n "$n" ] && [ "$n" -gt 0 ]; then
		sum=0; cnt=0
		for cpu in $(seq 0 $((n - 1))); do
			[ -r "$CPU_PATH/cpu${cpu}/cpufreq/scaling_cur_freq" ] || continue
			v=$(cat "$CPU_PATH/cpu${cpu}/cpufreq/scaling_cur_freq" 2>/dev/null)
			[ -n "$v" ] || continue
			sum=$((sum + v)); cnt=$((cnt + 1))
		done
		if [ "$cnt" -gt 0 ]; then
			avg=$((sum / cnt))
			echo -n "Freq: $(fmt_freq "$avg")"
		fi
	fi
}

read_cpu_temp_info() {
	local zone type temp cpu_temp

	for zone in "$THERMAL_PATH"/thermal_zone*; do
		[ -r "$zone/temp" ] || continue
		temp=$(cat "$zone/temp" 2>/dev/null)
		[ -n "$temp" ] || continue
		type=$(cat "$zone/type" 2>/dev/null)
		case "$type" in
			*cpu*|*CPU*|*package*|*soc*|*SOC*)
				cpu_temp=$(fmt_temp "$temp")
				break
				;;
		esac
	done

	# Fallback for platforms exposing only thermal_zone0.
	if [ -z "$cpu_temp" ] && [ -r "$THERMAL_PATH/thermal_zone0/temp" ]; then
		cpu_temp=$(fmt_temp "$(cat "$THERMAL_PATH/thermal_zone0/temp" 2>/dev/null)")
	fi

	[ -n "$cpu_temp" ] && echo -n "CPU: $cpu_temp" || echo -n "No CPU temperature info"
}

temp_info=$(read_cpu_temp_info)
freq_info=$(read_cpu_freq_info)

if [ -n "$freq_info" ]; then
	echo -n "$temp_info, $freq_info"
else
	echo -n "$temp_info"
fi
